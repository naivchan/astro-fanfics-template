---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <header class="ao3-global-header">
      <div class="header-inner">
        <a href="/" class="logo">ARCHIVE OF OUR OWN (ASTRO EDITION)</a>
      </div>
    </header>
    <main class="main-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --ao3-bg: #ffffff;
    --ao3-text: #2a2a2a;
    --ao3-red: #990000;         
    --ao3-red-hover: #660000;
    --ao3-blurb-bg: #ffffff;
    --ao3-meta-bg: #eee;        
    --ao3-border: #cccccc;
    --ao3-tag-text: #0066cc;
    --ao3-tag-hover: #004499;
    
    --rating-general: #00a000;  
    --rating-teen: #eed202;     
    --rating-mature: #ff9900;   
    --rating-explicit: #cc0000; 
  }

  body {
    margin: 0;
    padding: 0;
    background-color: var(--ao3-bg);
    color: var(--ao3-text);
    font-family: "Lucida Grande", "Lucida Sans Unicode", Verdana, Helvetica, sans-serif;
  }

  .ao3-global-header {
    background: var(--ao3-red);
    color: #fff;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #660000;
  }

  .header-inner .logo {
    color: #fff;
    font-weight: bold;
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.5px;
  }

  .main-content {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1rem;
  }
</style>
