---
import { getCollection } from 'astro:content'; 

interface Props {
  title: string;
  summary: string;
  pubDate: Date; 
  fandoms: string[];
  pairings?: string[];
  rating: 'General' | 'Teen' | 'Mature' | 'Explicit';
  status: 'Complete' | 'In Progress' | 'Hiatus';
  wordCount: number;
  slug: string;
  
  // New matching schema keys
  category?: 'M/M' | 'F/F' | 'F/M' | 'Multi' | 'Gen' | 'Other';
  warnings?: string[];

  chapters?: string; 
  isMultiChapter?: boolean;
  chapterNumber?: number;
  chaptersTotal?: string | number;
  seriesName?: string;
  seriesPart?: number;
}

const { 
  title, 
  summary, 
  pubDate,
  fandoms, 
  pairings = [], 
  rating, 
  status, 
  wordCount, 
  slug,
  category = "Gen",
  warnings = ["No Archive Warnings Apply"],
  chapters,
  isMultiChapter,
  chapterNumber = 1,
  chaptersTotal = "1",
  seriesName,
  seriesPart
} = Astro.props;

// --- AUTOMATIC COMPONENT SMART MATH ---
let displayWords = wordCount;
let displayChaptersTotal = chaptersTotal;
let displayChapterNumber = chapterNumber;

if (isMultiChapter) {
  // Fetch all fics right here inside the component
  const allFics = await getCollection('fanfics');
  const siblings = allFics.filter(f => f.data.title === title);
  
  // 1. Overwrite the total words dynamically
  displayWords = siblings.reduce((sum, s) => sum + (s.data.wordCount || 0), 0);
  
  // 2. Find the highest chapter number written
  const postedChapterNumbers = siblings.map(s => s.data.chapterNumber || 1);
  const highestChapterPosted = Math.max(...postedChapterNumbers);
  
  // 3. Match the logic based on Chapter 1's true master status
  const chapterOne = siblings.find(s => s.data.chapterNumber === 1);
  const masterStatus = chapterOne ? chapterOne.data.status : status;

  if (masterStatus === 'Complete') {
    displayChapterNumber = siblings.length;
    displayChaptersTotal = siblings.length;
  } else {
    displayChapterNumber = highestChapterPosted;
    displayChaptersTotal = chaptersTotal;
  }
} 

const ratingClass = rating.toLowerCase();
const categoryClass = category.toLowerCase().replace('/', '-');

// AO3 Warning shorthand: If it contains major alerts, color it red; otherwise clean gray/green
const hasMajorWarnings = warnings.some(w => w !== "No Archive Warnings Apply" && w !== "Choose Not To Use Archive Warnings");
const warningClass = hasMajorWarnings ? "major-warning" : "safe-warning";

const chaptersDisplay = chapters || (isMultiChapter ? `${displayChapterNumber}/${displayChaptersTotal}` : "1/1");

const formattedDate = pubDate ? new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
}) : '';
---

<div class="ao3-blurb">
  {seriesName && (
    <p class="series-meta">
      Part {seriesPart} of the <a href={`/series/${seriesName.toLowerCase().replace(/ /g, '-')}`}>{seriesName}</a> series
    </p>
  )}

  <div class="blurb-header">
    <!-- Authentic Grid Layout Elements -->
    <div class="ao3-symbols">
      <span class={`symbol rating-${ratingClass}`} title={`Rating: ${rating}`}></span>
      <span class={`symbol category-${categoryClass}`} title={`Category: ${category}`}>
        <span class="symbol-text">{category.charAt(0)}</span>
      </span>
      <span class={`symbol warning-${warningClass}`} title={`Warnings: ${warnings.join(', ')}`}></span>
      <span class={`symbol status-${status === 'Complete' ? 'complete' : 'incomplete'}`} title={`Status: ${status}`}></span>
    </div>

    <div class="title-block">
      <h3 class="heading">
        {isMultiChapter ? (
          /* Link to the index page created in work.astro */
          <a href={`/fanfics/${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
            {title}
          </a>
        ) : (
          /* Link directly to the single-chapter/one-shot reading view */
          <a href={`/fanfics/${slug}`}>{title}</a>
        )}
      </h3>
      <div class="fandoms">
        {fandoms.map((fandom, i) => (
          <span class="fandom-item">
            <a href={`/fandoms/${fandom.toLowerCase().replace(/ /g, '-')}`}>{fandom}</a>
            {i < fandoms.length - 1 && <span class="fandom-comma">, </span>}
          </span>
        ))}
      </div>
    </div>
  </div>

  <ul class="tags-list">
    {pairings.map(p => (
      <li class="tag pairing">
        <a href={`/pairings/${p.toLowerCase().replace(/[\/ ]/g, '-')}`}>{p}</a>
      </li>
    ))}
    {warnings.map(w => (
      <li class="tag warning-tag"><a href="#">{w}</a></li>
    ))}
  </ul>

  <blockquote class="summary">
    <p>{summary}</p>
  </blockquote>

  <div class="stats-footer">
    <dl class="stats">
      <div class="stat-group" style="display: flex; align-items: baseline;">
        <dt>Words:</dt>
        <dd>{displayWords.toLocaleString()}</dd>
      </div>
      <div class="stat-group" style="display: flex; align-items: baseline;">
        <dt>Chapters:</dt>
        <dd>{chaptersDisplay}</dd>
      </div>
      <div class="stat-group" style="display: flex; align-items: baseline;">
        <dt>Status:</dt>
        <dd>
          <a class="status-link" href={`/status/${status.toLowerCase().replace(/ /g, '-')}`}>{status}</a>
        </dd>
      </div>
      <div class="stat-group" style="margin-left: auto; text-align: right; display: flex; align-items: baseline;">
        <dt>Published:</dt>
        <dd>{formattedDate}</dd>
      </div>
    </dl>
  </div>
</div>

<style>
  .ao3-blurb { 
    border: 1px solid var(--ao3-border, #ccc); 
    padding: 1rem; 
    margin-bottom: 1.5rem; 
    background: var(--ao3-blurb-bg, #fff); 
    font-size: 0.9rem;
    box-sizing: border-box;
    width: 100%; /* Ensures the box never exceeds container boundaries */
  }
  .series-meta { font-style: italic; font-size: 0.85rem; margin: 0 0 0.5rem 0; color: #555; }
  .series-meta a { color: var(--ao3-red, #900); text-decoration: none; font-weight: bold; }
  .series-meta a:hover { text-decoration: underline; }
  
  /* --- 📱 RESPONSIVE HEADER LAYOUT --- */
  .blurb-header { 
    display: flex; 
    align-items: flex-start; 
    margin-bottom: 0.5rem; 
    gap: 0.75rem; /* Replaces direct margin-right for uniform alignment spacing */
  }

  .title-block {
    flex: 1; /* Automatically compresses and stretches based on viewport space */
    min-width: 0; /* Prevents long string/link overflows from blowing up the layout */
  }
  
  /* The Authentic Grid Layout */
  .ao3-symbols {
    display: grid;
    grid-template-columns: repeat(2, 14px);
    grid-template-rows: repeat(2, 14px);
    gap: 2px;
    border: 1px solid var(--ao3-border, #ccc);
    padding: 2px;
    margin-top: 4px;
    background: #fff;
    flex-shrink: 0; /* Prevents square shapes from getting squished flat on mobile */
  }
  .symbol { width: 14px; height: 14px; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: bold; color: #fff; text-transform: uppercase; }
  
  /* Color Code Mappings */
  .rating-general { background-color: #2a8314; }
  .rating-teen { background-color: #e2b100; }  
  .rating-mature { background-color: #df6400; } 
  .rating-explicit { background-color: #990000; }

  .category-m-m { background-color: #a52a2a; }  
  .category-f-f { background-color: #e66; }      
  .category-f-m { background-color: #89cff0; }  
  .category-gen { background-color: #999; }      
  .category-multi { background-color: #9370db; }
  .symbol-text { font-family: sans-serif; transform: scale(0.95); }

  .warning-safe-warning { background-color: #999; }
  .warning-major-warning { background-color: #990000; }

  .status-complete { background-color: #2a8314; }
  .status-incomplete { background-color: #990000; }

  .heading { margin: 0; word-wrap: break-word; overflow-wrap: break-word; }
  .heading a { color: var(--ao3-red, #900); text-decoration: none; font-weight: bold; font-size: 1.1rem; }
  .heading a:hover { text-decoration: underline; }
  .fandoms { font-weight: bold; font-size: 0.85rem; margin-top: 0.2rem; word-wrap: break-word; overflow-wrap: break-word; }
  .fandoms a { color: var(--ao3-red, #900); text-decoration: none; }
  .fandoms a:hover { text-decoration: underline; }
  
  .tags-list { margin: 0.5rem 0; padding: 0; display: block; word-wrap: break-word; overflow-wrap: break-word; }
  .tag { display: inline; font-size: 0.85rem; margin-right: 0.5rem; }
  .tag.pairing a { color: var(--ao3-tag-text, #444); font-weight: bold; text-decoration: none; }
  .tag.warning-tag a { color: #f75555; text-decoration: none; }
  .tag::after { content: ","; }
  .tag:last-child::after { content: ""; }

  .summary { margin: 0.75rem 0; padding-left: 0.75rem; border-left: 3px solid var(--ao3-border, #ccc); font-style: italic; }
  
  /* --- 📊 RESPONSIVE STATS BAR FOOTER --- */
  .stats { 
    margin: 0.5rem 0 0 0; 
    display: flex; 
    flex-wrap: wrap; /* Allows data points to wrap into clean rows on narrow screens */
    gap: 0.5rem 1rem;
    font-size: 0.8rem; 
  }
  .stat-group {
    display: flex;
    align-items: baseline;
  }
  .stats dt { font-weight: bold; margin-right: 0.25rem; }
  .stats dd { margin: 0; }
  .status-link { color: inherit; text-decoration: none; }
  .status-link:hover { text-decoration: underline; }

  /* Handle small-screen margin push for the published date */
  @media (min-width: 480px) {
    .stats .stat-group:last-child {
      margin-left: auto; 
      text-align: right;
    }
  }
</style>
