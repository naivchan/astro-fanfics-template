---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FicBlurb from '../components/FicBlurb.astro'; 

// Fetch all fics and sort them newest first
const allFics = await getCollection('fanfics');
const sortedFics = allFics.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Filter out duplicate pages for multi-chapter works so only Chapter 1 shows on the feed
const uniqueWorks = sortedFics.filter((fic) => {
  if (!fic.data.isMultiChapter) return true;
  return fic.data.chapterNumber === 1;
});

// --- 📊 DYNAMIC STATS CALCULATIONS ---
const totalWorksCount = uniqueWorks.length;
const totalWordCount = allFics.reduce((sum, fic) => sum + (fic.data.wordCount || 0), 0);
const uniqueFandomsCount = [...new Set(uniqueWorks.flatMap(f => f.data.fandoms || []))].length;
const ongoingWorksCount = uniqueWorks.filter(f => f.data.status?.toLowerCase() === 'in progress' || f.data.status?.toLowerCase() === 'ongoing').length;

const uniqueFandoms = [...new Set(uniqueWorks.flatMap(f => f.data.fandoms || []))].sort();
const uniquePairings = [...new Set(uniqueWorks.flatMap(f => f.data.pairings || []))].sort();
const uniqueRatings = [...new Set(uniqueWorks.map(f => f.data.rating).filter(Boolean))];
const uniqueStatuses = [...new Set(uniqueWorks.map(f => f.data.status).filter(Boolean))];
---

<Layout title="Works Archive">
  <main class="main-content archive-container">

    <nav class="archive-nav">
      <div class="nav-links">
        <a href="/" class="nav-item current">Home</a>
        <a href="/fandoms" class="nav-item">Browse Fandoms</a>
      </div>
    </nav>

    <div class="archive-stats-bar">
      <div class="stat-pill">
        <span class="stat-icon">📚</span>
        <span class="stat-label">Works:</span>
        <span class="stat-value">{totalWorksCount}</span>
      </div>
      <div class="stat-pill">
        <span class="stat-icon">✍️</span>
        <span class="stat-label">Total Words:</span>
        <span class="stat-value">{totalWordCount.toLocaleString()}</span> </div>
      <div class="stat-pill">
        <span class="stat-icon">✨</span>
        <span class="stat-label">Fandoms:</span>
        <span class="stat-value">{uniqueFandomsCount}</span>
      </div>
      <div class="stat-pill">
        <span class="stat-icon">⏳</span>
        <span class="stat-label">Ongoing:</span>
        <span class="stat-value">{ongoingWorksCount}</span>
      </div>
    </div>

    <hr class="nav-divider" />

    <button id="mobile-filter-toggle" class="mobile-filter-btn" aria-expanded="false">
      <span class="btn-icon">⚙️</span> Filter & Refine Works
    </button>

    <div class="archive-layout">
      
      <section class="feed-column">
        <div class="filter-results-summary" id="results-summary">
          Showing All {uniqueWorks.length} Works
        </div>

        <div class="works-feed">
            {uniqueWorks.map((fic) => {
              return (
              <div 
                class="filterable-work-card"
                data-fandoms={JSON.stringify(fic.data.fandoms || [])}
                data-pairings={JSON.stringify(fic.data.pairings || [])}
                data-rating={fic.data.rating}
                data-status={fic.data.status}
              >
                <FicBlurb 
                  title={fic.data.title}
                  slug={fic.slug}
                  summary={fic.data.summary}
                  pubDate={fic.data.pubDate}
                  fandoms={fic.data.fandoms}
                  pairings={fic.data.pairings || []}
                  rating={fic.data.rating}
                  status={fic.data.status}
                  wordCount={fic.data.wordCount}
                  category={fic.data.category}
                  warnings={fic.data.warnings}
                  isMultiChapter={fic.data.isMultiChapter}
                  chapterNumber={fic.data.chapterNumber} 
                  chaptersTotal={fic.data.chaptersTotal}
                  seriesName={fic.data.seriesName}
                  seriesPart={fic.data.seriesPart}
                />
              </div>
            );
          })}
        </div>
      </section>

      <aside class="filter-sidebar mobile-drawer" id="filter-sidebar">
        <div class="sidebar-header">
          <h3>Filter Results</h3>
          <button id="mobile-filter-close" class="mobile-close-btn" aria-label="Close filters">×</button>
        </div>
        
        <form id="filter-form">
          <details open class="filter-group">
            <summary>Fandoms</summary>
            <div class="filter-choices">
              {uniqueFandoms.map(fandom => (
                <label class="choice-label">
                  <input type="checkbox" name="fandom" value={fandom} /> {fandom}
                </label>
              ))}
            </div>
          </details>

          <details open class="filter-group">
            <summary>Relationships</summary>
            <div class="filter-choices">
              {uniquePairings.map(pairing => (
                <label class="choice-label">
                  <input type="checkbox" name="pairing" value={pairing} /> {pairing}
                </label>
              ))}
            </div>
          </details>

          <details open class="filter-group">
            <summary>Rating</summary>
            <div class="filter-choices">
              {uniqueRatings.map(rating => (
                <label class="choice-label">
                  <input type="checkbox" name="rating" value={rating} /> {rating}
                </label>
              ))}
            </div>
          </details>

          <details open class="filter-group">
            <summary>Status</summary>
            <div class="filter-choices">
              {uniqueStatuses.map(status => (
                <label class="choice-label">
                  <input type="checkbox" name="status" value={status} /> {status}
                </label>
              ))}
            </div>
          </details>

          <button type="reset" id="reset-filters" class="ao3-button">Clear Filters</button>
        </form>
      </aside>

    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('filter-form') as HTMLFormElement;
  const cards = document.querySelectorAll('.filterable-work-card') as NodeListOf<HTMLElement>;
  const summary = document.getElementById('results-summary');
  const resetBtn = document.getElementById('reset-filters');
  const openDrawerBtn = document.getElementById('mobile-filter-toggle');
  const closeDrawerBtn = document.getElementById('mobile-filter-close');
  const sidebarDrawer = document.getElementById('filter-sidebar');

  openDrawerBtn?.addEventListener('click', () => {
    sidebarDrawer?.classList.add('is-open');
    openDrawerBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  });

  function closeDrawer() {
    sidebarDrawer?.classList.remove('is-open');
    openDrawerBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  closeDrawerBtn?.addEventListener('click', closeDrawer);

  function updateFilters() {
    const formData = new FormData(form);
    const selectedFandoms = formData.getAll('fandom') as string[];
    const selectedPairings = formData.getAll('pairing') as string[];
    const selectedRatings = formData.getAll('rating') as string[];
    const selectedStatuses = formData.getAll('status') as string[];

    let visibleCount = 0;

    cards.forEach(card => {
      const cardFandoms = JSON.parse(card.dataset.fandoms || '[]') as string[];
      const cardPairings = JSON.parse(card.dataset.pairings || '[]') as string[];
      const cardRating = card.dataset.rating || '';
      const cardStatus = card.dataset.status || '';

      const fandomMatch = selectedFandoms.length === 0 || selectedFandoms.some(f => cardFandoms.includes(f));
      const pairingMatch = selectedPairings.length === 0 || selectedPairings.some(p => cardPairings.includes(p));
      const ratingMatch = selectedRatings.length === 0 || selectedRatings.includes(cardRating);
      const statusMatch = selectedStatuses.length === 0 || selectedStatuses.includes(cardStatus);

      if (fandomMatch && pairingMatch && ratingMatch && statusMatch) {
        card.style.display = 'block';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (summary) {
      summary.textContent = `Showing ${visibleCount} of ${cards.length} Works`;
    }
  }

  form?.addEventListener('change', updateFilters);
  resetBtn?.addEventListener('click', () => {
    setTimeout(() => {
      updateFilters();
      closeDrawer();
    }, 10);
  });
</script>

<style>
  /* --- 🏛️ AO3 GLOBAL SETTINGS & PALETTE --- */
  :root {
    --ao3-red: #990000;
    --ao3-light-red: #faecec;
    --ao3-border-gray: #ccc;
    --ao3-bg-gray: #eee;
    --ao3-text-dark: #333;
  }

  .archive-container {
    max-width: 1200px; /* Widened slightly for the desktop sidebar layout */
    margin: 2rem auto;
    padding: 0 1rem;
    font-family: "Lucida Grande", "Lucida Sans Unicode", "GNU Unifont", Verdana, Helvetica, sans-serif;
    color: var(--ao3-text-dark);
  }

  /* --- 🏷️ HEADER & NAVIGATION (KEPT FROM YOUR ORIGINAL) --- */
  .archive-header {
    text-align: center;
    border-bottom: 2px solid var(--ao3-border-gray);
    padding-bottom: 1rem;
    margin-bottom: 2.5rem;
  }
  .archive-header h1 {
    font-family: Georgia, serif;
    font-size: 2.5rem;
    font-weight: normal;
    margin: 0;
  }
  .subtitle {
    color: #666;
    font-style: italic;
    margin-top: 0.5rem;
  }
  .works-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .archive-nav {
    background: #eaeaea;
    border: 1px solid var(--ao3-border-gray);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    margin: 1rem auto 1.5rem auto;
    max-width: 100%;
  }
  .nav-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
  }
  .nav-item {
    color: var(--ao3-red);
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    padding: 0.25rem 0.5rem;
  }
  .nav-item:hover {
    text-decoration: underline;
  }
  .nav-item.current {
    color: #333;
    border-bottom: 2px solid #333;
    pointer-events: none;
  }
  .nav-divider {
    border: 0;
    border-top: 1px solid var(--ao3-border-gray);
    margin-bottom: 2rem;
  }

  /* --- 📊 AO3 DYNAMIC STATS BAR --- */
  .archive-stats-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    background-color: var(--ao3-bg-gray);
    border: 1px solid var(--ao3-border-gray);
    border-radius: 4px;
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  .stat-pill {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding-right: 1rem;
    border-right: 1px solid var(--ao3-border-gray);
  }
  .stat-pill:last-child {
    border-right: none;
  }
  .stat-icon {
    display: none; /* AO3 relies on text layouts over icons */
  }
  .stat-label {
    font-weight: bold;
    color: var(--ao3-text-dark);
  }
  .stat-value {
    color: var(--ao3-red);
    font-weight: bold;
  }

  /* --- 🎛️ ARCHIVE LAYOUT & SIDEBAR --- */
  .archive-layout {
    display: grid;
    grid-template-columns: 1fr 280px; /* Traditional AO3 right-aligned layout */
    gap: 1.5rem;
    align-items: start;
  }
  .feed-column {
    order: 1;
  }
  .filter-results-summary {
    background: #f4f4f4;
    border: 1px solid var(--ao3-border-gray);
    padding: 0.4rem 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    font-weight: bold;
    color: #444;
    border-radius: 3px;
  }
  .filter-sidebar {
    order: 2;
    background: #fff;
    border: 1px solid var(--ao3-border-gray);
    border-radius: 4px;
    box-shadow: 1px 1px 3px rgba(0,0,0,0.1);
    padding: 1rem;
  }
  .sidebar-header h3 {
    margin-top: 0;
    font-family: Georgia, serif;
    color: var(--ao3-red);
    border-bottom: 1px solid var(--ao3-border-gray);
    padding-bottom: 0.5rem;
    font-size: 1.2rem;
    font-weight: normal;
  }
  .sidebar-header .mobile-close-btn {
    display: none;
  }

  /* --- 📂 AO3 FILTER DETAILS GROUP --- */
  .filter-group {
    border: 1px solid var(--ao3-border-gray);
    border-radius: 4px;
    margin-bottom: 0.75rem;
    background: #fff;
  }
  .filter-group summary {
    background: var(--ao3-bg-gray);
    padding: 0.4rem 0.6rem;
    font-weight: bold;
    cursor: pointer;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--ao3-border-gray);
    list-style: none;
    user-select: none;
  }
  .filter-group summary::-webkit-details-marker {
    display: none;
  }
  .filter-choices {
    padding: 0.5rem;
    max-height: 200px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .choice-label {
    font-size: 0.85rem;
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    cursor: pointer;
    color: #444;
  }
  .choice-label input[type="checkbox"] {
    margin-top: 0.15rem;
    cursor: pointer;
  }

  /* --- 🛑 AO3 PLAIN GRADIENT BUTTONS --- */
  .ao3-button {
    display: block;
    width: 100%;
    text-align: center;
    background: #eee;
    background: linear-gradient(#fff, #e1e1e1);
    border: 1px solid #bbb;
    border-color: #bbb #aaa #999;
    border-radius: 4px;
    padding: 0.4rem;
    font-size: 0.85rem;
    font-weight: bold;
    color: #333;
    cursor: pointer;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 1px 2px rgba(0,0,0,0.05);
    margin-top: 0.5rem;
  }
  .ao3-button:hover {
    background: #ddd;
    background: linear-gradient(#eee, #ccc);
    border-color: #999 #888 #777;
    color: #222;
  }

  /* --- 📱 RESPONSIVE & MOBILE DRAWING SYSTEM --- */
  .mobile-filter-btn {
    display: none; /* Completely hidden on desktop */
  }

  @media (max-width: 768px) {
    .mobile-filter-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--ao3-red);
      color: white;
      border: 1px solid #700;
      padding: 0.6rem 1rem;
      border-radius: 4px;
      font-weight: bold;
      font-size: 0.95rem;
      cursor: pointer;
      margin-bottom: 1rem;
      width: 100%;
      justify-content: center;
    }
    .archive-layout {
      grid-template-columns: 1fr;
    }
    .feed-column {
      order: 2;
    }
    .filter-sidebar.mobile-drawer {
      order: 1;
      position: fixed;
      top: 0;
      right: -100%; /* Hidden off-screen by default */
      width: 85%;
      max-width: 340px;
      height: 100vh;
      background: white;
      z-index: 1000;
      box-shadow: -2px 0 10px rgba(0,0,0,0.2);
      transition: right 0.3s ease;
      overflow-y: auto;
      padding: 1.5rem;
      box-sizing: border-box;
    }
    .filter-sidebar.mobile-drawer.is-open {
      right: 0; /* Sliding into view via JS toggle triggers */
    }
    .sidebar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    .sidebar-header h3 {
      border-bottom: none;
      margin: 0;
    }
    .sidebar-header .mobile-close-btn {
      display: block;
      background: transparent;
      border: none;
      font-size: 1.75rem;
      color: #666;
      cursor: pointer;
      line-height: 1;
    }
  }
</style>
