---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FicBlurb from '../components/FicBlurb.astro';

export async function getStaticPaths({ paginate }) {
  const allFics = await getCollection('fanfics');
  const sortedFics = allFics.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  
  // Filter down to unique works (Entry point only)
  const uniqueWorks = sortedFics.filter(fic => !fic.data.isMultiChapter || fic.data.chapterNumber === 1);
  
  // Paginate with 20 works per page
  return paginate(uniqueWorks, { pageSize: 20 });
}

const { page } = Astro.props;
---

<Layout title={`Works Archive - Page ${page.currentPage}`}>
  <main class="archive-container">
    <header class="archive-header">
      <h1>Works Archive</h1>
    </header>

    <div class="works-feed">
      {page.data.map((fic) => (
        <FicBlurb {...fic.data} slug={fic.slug} />
      ))}
    </div>

    <nav class="pagination">
      {page.url.prev ? <a href={page.url.prev}>← Previous</a> : <span class="disabled">← Previous</span>}
      <span class="page-count">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? <a href={page.url.next}>Next →</a> : <span class="disabled">Next →</span>}
    </nav>
  </main>
</Layout>

<style>
  .pagination { display: flex; justify-content: center; gap: 2rem; margin-top: 3rem; font-size: 0.9rem; }
  .pagination a { color: var(--ao3-red); font-weight: bold; text-decoration: none; }
  .pagination .disabled { color: #999; }
</style>
