---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/layout.astro'; // Uses lowercase matching your setup

const allFics = await getCollection('fanfics');

// Filter down to unique entries only (ignore subsequent chapters so we don't double-count multi-chapter works)
const uniqueWorks = allFics.filter(fic => !fic.data.isMultiChapter || fic.data.chapterNumber === 1);

// Create an object map to keep track of fandom counts: { "Original Work": 3, "Anime": 1 }
const fandomCounts: Record<string, number> = {};

uniqueWorks.forEach((fic) => {
  if (fic.data.fandoms) {
    fic.data.fandoms.forEach((fandom: string) => {
      // Trim accidental spaces to keep keys uniform
      const cleanFandom = fandom.trim();
      if (fandomCounts[cleanFandom]) {
        fandomCounts[cleanFandom] += 1;
      } else {
        fandomCounts[cleanFandom] = 1;
      }
    });
  }
});

// Convert the map into an array of objects, then sort alphabetically by fandom name
const sortedFandoms = Object.keys(fandomCounts)
  .map(name => ({
    name,
    count: fandomCounts[name],
    slug: name.toLowerCase().replace(/ /g, '-')
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="Fandoms Index">
  <main class="fandoms-index-container">
    <header class="index-header">
      <h2>Fandoms</h2>
      <p class="subtitle">Select a fandom to browse its creative archive.</p>
    </header>

    <hr class="ao3-divider" />

    <ul class="fandoms-list">
      {sortedFandoms.map((fandom) => (
        <li class="fandom-item">
          <a class="fandom-link" href={`/fandoms/${fandom.slug}`}>
            {fandom.name}
          </a>
          <span class="work-count">({fandom.count})</span>
        </li>
      ))}
    </ul>
    
    {sortedFandoms.length === 0 && (
      <p class="empty-notice">No fandom entries found in the archive repository yet.</p>
    )}
  </main>
</Layout>

<style>
  .fandoms-index-container {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1rem;
    font-family: Arial, sans-serif;
  }
  .index-header h2 {
    font-family: Georgia, serif;
    color: #900;
    font-size: 1.8rem;
    font-weight: normal;
    margin: 0 0 0.25rem 0;
    border-bottom: 1px solid var(--ao3-border, #ccc);
    padding-bottom: 0.5rem;
  }
  .subtitle {
    font-size: 0.9rem;
    color: #555;
    margin: 0.5rem 0;
    font-style: italic;
  }
  .ao3-divider {
    border: 0;
    border-top: 1px solid var(--ao3-border, #ccc);
    margin: 1.5rem 0;
  }
  .fandoms-list {
    list-style-type: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .fandom-item {
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .fandom-link {
    color: var(--ao3-red, #900);
    text-decoration: none;
    font-weight: bold;
  }
  .fandom-link:hover {
    text-decoration: underline;
  }
  .work-count {
    color: #555;
    font-size: 0.9rem;
  }
  .empty-notice {
    color: #666;
    font-style: italic;
    text-align: center;
    margin-top: 3rem;
  }
</style>
