---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FicBlurb from '../components/FicBlurb.astro'; // Assuming it lives in src/components/

// Fetch all fics and sort them newest first
const allFics = await getCollection('fanfics');
const sortedFics = allFics.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Filter out duplicate pages for multi-chapter works so only Chapter 1 shows on the feed
const uniqueWorks = sortedFics.filter((fic) => {
  if (!fic.data.isMultiChapter) return true;
  return fic.data.chapterNumber === 1;
});
---

<Layout title="Works Archive">
  <main class="archive-container">
    <header class="archive-header">
      <h1>Works Archive</h1>
      <p class="subtitle">Latest creative fiction and ongoing narratives</p>
    </header>

    <nav class="archive-nav">
      <div class="nav-links">
        <a href="/" class="nav-item current">Home</a>
        <a href="/fandoms" class="nav-item">Browse Fandoms</a>
      </div>
    </nav>

    <hr class="nav-divider" />

    <div class="works-feed">
      {uniqueWorks.map((fic) => (
        <FicBlurb 
          title={fic.data.title}
          slug={fic.slug}
          summary={fic.data.summary}
          pubDate={fic.data.pubDate}
          fandoms={fic.data.fandoms}
          pairings={fic.data.pairings || []}
          rating={fic.data.rating}
          status={fic.data.status}
          wordCount={fic.data.wordCount}
          isMultiChapter={fic.data.isMultiChapter}
          chapterNumber={fic.data.chapterNumber || 1}
          chaptersTotal={fic.data.chaptersTotal || "1"}
          seriesName={fic.data.seriesName}
          seriesPart={fic.data.seriesPart}
        />
      ))}
    </div>
  </main>
</Layout>

<style>
  .archive-container {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  .archive-header {
    text-align: center;
    border-bottom: 2px solid var(--ao3-border, #ccc);
    padding-bottom: 1rem;
    margin-bottom: 2.5rem;
  }
  .archive-header h1 {
    font-family: Georgia, serif;
    font-size: 2.5rem;
    font-weight: normal;
    margin: 0;
  }
  .subtitle {
    color: #666;
    font-style: italic;
    margin-top: 0.5rem;
  }
  .works-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem; /* Let FicBlurb handle its own internal styling and padding */
  }

  /* Added Navigation Interface Styles */
  .archive-nav {
    background: #eaeaea;
    border: 1px solid var(--ao3-border, #ccc);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    margin: 1rem auto 1.5rem auto;
    max-width: 100%;
  }
  .nav-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
  }
  .nav-item {
    color: var(--ao3-red, #900);
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    padding: 0.25rem 0.5rem;
  }
  .nav-item:hover {
    text-decoration: underline;
  }
  .nav-item.current {
    color: #333;
    border-bottom: 2px solid #333;
    pointer-events: none;
  }
  .nav-divider {
    border: 0;
    border-top: 1px solid var(--ao3-border, #ccc);
    margin-bottom: 2rem;
  }
</style>
