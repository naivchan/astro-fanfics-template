---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const fics = await getCollection('fanfics');
  return fics.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, allFics: fics },
  }));
}

const { entry, allFics } = Astro.props;
const { Content } = await entry.render();

// --- Chapter Navigation Logic (Folder Based) ---
let siblingChapters = [];
let prevChapter = null;
let nextChapter = null;

if (entry.data.isMultiChapter && entry.data.chapterNumber) {
  // Get the folder path of the current file (e.g., "specific-story-folder")
  const currentFolder = entry.id.split('/')[0];
  
  siblingChapters = allFics
    .filter(f => f.id.startsWith(currentFolder + '/') && f.data.isMultiChapter)
    .sort((a, b) => (a.data.chapterNumber || 0) - (b.data.chapterNumber || 0));

  prevChapter = siblingChapters.find(ch => ch.data.chapterNumber === entry.data.chapterNumber - 1);
  nextChapter = siblingChapters.find(ch => ch.data.chapterNumber === entry.data.chapterNumber + 1);
}
---

<Layout title={entry.data.title}>
  <div class="ao3-meta-box">
    <dl class="meta-group">
      <!-- Live Rating Link -->
      <dt>Rating:</dt> 
      <dd>
        <a class="meta-link" href={`/rating/${entry.data.rating.toLowerCase()}`}>{entry.data.rating}</a>
      </dd>

      <!-- New Live Category Metric -->
      <dt>Category:</dt>
      <dd>{entry.data.category || "Gen"}</dd>
      
      <!-- Live Fandom Links -->
      <dt>Fandom:</dt> 
      <dd>
        {entry.data.fandoms.map((fandom, i) => (
          <span>
            <a class="meta-link" href={`/fandoms/${fandom.toLowerCase().replace(/ /g, '-')}`}>{fandom}</a>
            {i < entry.data.fandoms.length - 1 && ", "}
          </span>
        ))}
      </dd>
      
      <!-- Live Relationship Links -->
      {entry.data.pairings && (
        <dt>Relationship:</dt> 
        <dd class="pairing">
          {entry.data.pairings.map((pairing, i) => (
            <span>
              <a class="pairing-link" href={`/pairings/${pairing.toLowerCase().replace(/[\/ ]/g, '-')}`}>{pairing}</a>
              {i < entry.data.pairings.length - 1 && ", "}
            </span>
          ))}
        </dd>
      )}


      <!-- New Warnings Row -->
      <dt>Archive Warning:</dt>
      <dd class="meta-warnings">{ (entry.data.warnings || ["No Archive Warnings Apply"]).join(', ') }</dd>

      <!-- Stats Block with Live Status Link -->
      <dt>Stats:</dt>
      <dd>
        <span><strong>Words:</strong> {entry.data.wordCount.toLocaleString()}</span> | 
        <span><strong>Chapters:</strong> {entry.data.isMultiChapter ? `${entry.data.chapterNumber}/${entry.data.chaptersTotal}` : "1/1"}</span> | 
        <span><strong>Status:</strong> <a class="meta-link" href={`/status/${entry.data.status.toLowerCase().replace(/ /g, '-')}`}>{entry.data.status}</a></span>
      </dd>
    </dl>
  </div>

  <div class="preface">
    {entry.data.seriesName && (
      <p class="series-meta">
        Part {entry.data.seriesPart} of the <a href={`/series/${entry.data.seriesName.toLowerCase().replace(/ /g, '-')}`}>{entry.data.seriesName}</a> series
      </p>
    )}
    
    <!-- Overarching Work Title -->
    <h1 class="story-title">{entry.data.title}</h1>
    
    <!-- AO3 Chapter Header Placement -->
    {entry.data.isMultiChapter && (
      <h2 class="chapter-title">
        Chapter {entry.data.chapterNumber}: {entry.data.chapterTitle || `Chapter ${entry.data.chapterNumber}`}
      </h2>
    )}
    
    <div class="summary-box">
      <strong>Summary:</strong>
      <p>{entry.data.summary}</p>
    </div>
  </div>

  <hr />

  <article class="story-body">
    <Content />
  </article>

  {entry.data.isMultiChapter && siblingChapters.length > 1 && (
    <nav class="chapter-navigation">
      <div class="nav-button">
        {prevChapter && <a href={`/fanfics/${prevChapter.slug}`}>← Previous Chapter</a>}
      </div>
      
      <div class="chapter-dropdown">
        <label for="chapter-select">Chapter: </label>
        <select id="chapter-select" onchange="window.location.href=this.value">
          {siblingChapters.map(ch => (
            <option value={`/fanfics/${ch.slug}`} selected={ch.data.chapterNumber === entry.data.chapterNumber}>
              {ch.data.chapterNumber} of {entry.data.chaptersTotal}
            </option>
          ))}
        </select>
      </div>

      <div class="nav-button" style="text-align: right;">
        {nextChapter && <a href={`/fanfics/${nextChapter.slug}`}>Next Chapter →</a>}
      </div>
    </nav>
  )}
</Layout>

<style>
  .series-meta { font-style: italic; font-size: 0.95rem; margin-bottom: 0.5rem; color: #555; }
  .series-meta a { color: var(--ao3-red); text-decoration: none; font-weight: bold; }
  .series-meta a:hover { text-decoration: underline; }
  
  .chapter-title {
    font-family: Georgia, serif;
    font-size: 1.4rem;
    font-weight: normal;
    color: #444;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .chapter-navigation { display: flex; justify-content: space-between; align-items: center; margin: 2.5rem 0; padding: 0.5rem; border-top: 1px solid var(--ao3-border); border-bottom: 1px solid var(--ao3-border); background: #fcfcfc; font-size: 0.9rem; }
  .nav-button { width: 30%; }
  .nav-button a { color: var(--ao3-red); text-decoration: none; font-weight: bold; }
  .chapter-dropdown { width: 40%; text-align: center; }
  
  .ao3-meta-box { background: var(--ao3-meta-bg); border: 1px solid var(--ao3-border); padding: 1rem; font-size: 0.85rem; margin-bottom: 2rem; }
  .meta-group { display: grid; grid-template-columns: 120px 1fr; gap: 0.4rem 0; margin: 0; }
  .meta-group dt { font-weight: bold; text-align: right; padding-right: 1rem; color: #333; }
  .meta-group dd { margin: 0; }
  .meta-warnings { color: #f75555; }
  
  /* Link Styling for Metadata Boxes */
  .meta-link { color: var(--ao3-red); text-decoration: none; }
  .meta-link:hover { text-decoration: underline; }
  .pairing-link { color: var(--ao3-tag-text); font-weight: bold; text-decoration: none; }
  .pairing-link:hover { text-decoration: underline; }

  .preface { text-align: center; margin: 2rem 0; }
  .story-title { font-family: Georgia, serif; font-size: 2rem; font-weight: normal; margin-bottom: 0; }
  .summary-box { text-align: left; max-width: 600px; margin: 1.5rem auto; border: 1px solid var(--ao3-border); padding: 1rem; background: #fff; font-size: 0.9rem; }
  .story-body { font-family: Georgia, serif; font-size: 1.15rem; line-height: 1.7; max-width: 700px; margin: 0 auto; }
  .story-body :global(p) { margin-bottom: 1.5rem; }
</style>
